# ─── Payload CMS ───────────────────────────────────────────────
PAYLOAD_SECRET=your-random-secret-here-min-32-chars

# ─── PostgreSQL ─────────────────────────────────────────────────
# Use DATABASE_URL_UNPOOLED from Neon (direct connection — Payload manages its own pool)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Next.js ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://netherlandsbagels.com

# ─── Vercel Blob Storage (for image/video uploads) ───────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
